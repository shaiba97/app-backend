# =============================================================================
# RIHLA - Environment Configuration Example
# =============================================================================
# IMPORTANT: Copy this file to .env and update values for your environment
# NEVER commit actual .env file to repository
# NEVER expose secrets in version control
# =============================================================================

# =============================================================================
# NODE ENVIRONMENT
# =============================================================================
# Options: development, staging, production, test
NODE_ENV=development

# =============================================================================
# MICROSERVICE PORT CONFIGURATION
# =============================================================================
# Each service runs on its own port (backend only, frontends use different servers)
ADMIN_PORT=3000
COMPANY_PORT=3001
CUSTOMER_PORT=3002

# =============================================================================
# DATABASE CONFIGURATION - PostgreSQL
# =============================================================================
# REQUIRED: Update with your database credentials
# Format: postgresql://[user[:password]@][netloc][:port][/dbname][?param1=value1&...]
#
# Local Development:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/rihla_dev
#
# Neon Cloud (use connection pooler):
# DATABASE_URL=postgresql://user:password@host-pooler.region.postgres.neon.tech/database?sslmode=require
#
# AWS RDS:
# DATABASE_URL=postgresql://admin:password@rihla-db.xxx.us-east-1.rds.amazonaws.com:5432/rihla
#
# Render PostgreSQL (auto-provided):
# DATABASE_URL=postgresql://user:password@render-host:5432/rihla
DATABASE_URL=postgresql://postgres:password@localhost:5432/rihla_dev

# =============================================================================
# REDIS CACHE CONFIGURATION
# =============================================================================
# REQUIRED: Cache service for sessions, caching, and real-time features
#
# Local Development:
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Production (Redis Cloud, Upstash, or AWS ElastiCache):
# REDIS_HOST=redis-cloud-host.com
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
# REQUIRED: Secret key for signing JWT tokens
# SECURITY: Use strong random string (32+ characters, mix of upper/lower/numbers/special)
# WARNING: Changing this in production will invalidate all existing tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# ❌ DO NOT use this value in production:
JWT_SECRET=dev-secret-key-change-in-production-generate-new-random-value

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# REQUIRED: Comma-separated list of allowed frontend origins
#
# Local Development:
CORS_ORIGINS=http://localhost:4000,http://localhost:4100,http://localhost:4200

# Production (UPDATE WITH YOUR ACTUAL DOMAINS):
# CORS_ORIGINS=https://admin.yourdomain.com,https://company.yourdomain.com,https://customer.yourdomain.com

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================
# Directory for storing uploaded files
UPLOAD_DIR=./uploads

# Maximum file upload size in bytes (50MB = 52428800)
# For production: Consider using object storage (AWS S3, Azure Blob, etc.)
MAX_UPLOAD_SIZE=52428800

# =============================================================================
# WHATSAPP INTEGRATION (OPTIONAL)
# =============================================================================
# Enable/disable WhatsApp notifications
WHATSAPP_ENABLED=false

# WhatsApp Business Account credentials (get from Meta/WhatsApp Business)
# Only required if WHATSAPP_ENABLED=true
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=

# =============================================================================
# FRONTEND API URLs (Used by frontend apps)
# =============================================================================
# Local Development:
ADMIN_API_URL=http://localhost:3000/api
COMPANY_API_URL=http://localhost:3001/api
CUSTOMER_API_URL=http://localhost:3002/api

# Production (UPDATE WITH YOUR ACTUAL DOMAINS):
# ADMIN_API_URL=https://admin-api.yourdomain.com/api
# COMPANY_API_URL=https://company-api.yourdomain.com/api
# CUSTOMER_API_URL=https://customer-api.yourdomain.com/api

# =============================================================================
# OPTIONAL: PAYMENT GATEWAY CONFIGURATION
# =============================================================================
# Stripe Integration (future feature)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLIC_KEY=pk_test_...

# PayPal Integration (future feature)
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=

# =============================================================================
# OPTIONAL: EMAIL CONFIGURATION
# =============================================================================
# SMTP Configuration for email notifications
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@yourdomain.com

# =============================================================================
# OPTIONAL: SMS CONFIGURATION
# =============================================================================
# Twilio SMS Integration
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# =============================================================================
# ENVIRONMENT-SPECIFIC EXAMPLES
# =============================================================================

# LOCAL DEVELOPMENT (.env for development)
# NODE_ENV=development
# DATABASE_URL=postgresql://postgres:password@localhost:5432/rihla_dev
# REDIS_HOST=localhost
# JWT_SECRET=dev-local-secret-123
# CORS_ORIGINS=http://localhost:4000,http://localhost:4100,http://localhost:4200

# DOCKER/COMPOSE (docker-compose.yml will override)
# NODE_ENV=development
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/rihla
# REDIS_HOST=redis
# JWT_SECRET=docker-dev-secret
# CORS_ORIGINS=http://localhost:4000,http://localhost:4100,http://localhost:4200

# RENDER DEPLOYMENT (set in Render dashboard, not in .env)
# NODE_ENV=production
# DATABASE_URL=postgresql://... (auto-linked from Render PostgreSQL)
# REDIS_HOST=... (auto-linked from Render Redis)
# JWT_SECRET=long-random-production-secret-set-in-render-dashboard
# CORS_ORIGINS=https://admin.yourdomain.com,https://company.yourdomain.com,https://customer.yourdomain.com

# AWS DEPLOYMENT
# NODE_ENV=production
# DATABASE_URL=postgresql://user:pass@rihla-db.xxx.rds.amazonaws.com/rihla
# REDIS_HOST=rihla-cache.xxx.cache.amazonaws.com
# JWT_SECRET=long-random-production-secret-stored-in-aws-secrets-manager
# CORS_ORIGINS=https://admin.yourdomain.com,https://company.yourdomain.com,https://customer.yourdomain.com

# =============================================================================
# SECURITY CHECKLIST
# =============================================================================
# Before deployment, verify:
# ✅ DATABASE_URL uses strong password (16+ characters)
# ✅ JWT_SECRET is long random value (32+ characters), unique per environment
# ✅ REDIS_PASSWORD is set in production (if not using managed service)
# ✅ CORS_ORIGINS only includes legitimate domains
# ✅ .env file is in .gitignore (NEVER commit)
# ✅ No secrets exposed in logs
# ✅ Use environment secret managers in production (AWS Secrets, HashiCorp Vault, etc.)
# ✅ Rotate secrets regularly
# ✅ Enable database encryption at rest
# ✅ Use SSL/TLS for all connections

# =============================================================================
# GETTING STARTED
# =============================================================================
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Update values for your environment
#
# 3. For local development:
#    - Install PostgreSQL and Redis locally, OR
#    - Use Docker Compose: docker-compose up -d
#
# 4. Start the application:
#    cd backend && npm install
#    npx prisma migrate dev
#    npm run start:all
#
# 5. For production:
#    - Use secure secret management
#    - Store secrets in environment-specific secret managers
#    - Never commit actual .env file
#    - Use strong, randomly generated secrets
